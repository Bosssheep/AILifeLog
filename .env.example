# 环境变量配置文件示例
# 复制此文件为 .env 并修改相应值

# 前端 API 基础地址 (Vite 环境变量)
VITE_API_BASE_URL=http://localhost:4000

# JWT 密钥 (后端使用)
JWT_SECRET=your-default-secret-for-development

# 后端端口 (Railway 会自动设置 PORT)
# PORT=4000

# 生产环境部署说明:
# 1. Railway 会自动设置 PORT 环境变量
# 2. 在 Railway 控制台设置 JWT_SECRET 为强密码
# 3. 在 Vercel 环境变量中设置 VITE_API_BASE_URL 为 Railway 后端地址